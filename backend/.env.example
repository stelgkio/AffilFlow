# Copy to .env and adjust.

APP_ENV=development
HTTP_PORT=8080

# PostgreSQL — URL form (matches typical .NET style "Host=...;Database=..."):
#   postgres://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=disable
# Default: database name affilflow on your existing server (not ceres / other apps).
DATABASE_URL=postgres://postgres:postgres@localhost:5432/affilflow?sslmode=disable
#
# Create the DB once if needed:  CREATE DATABASE affilflow;
# Migrations add AffilFlow tables only inside this database.

# Apply SQL migrations on startup (dev convenience)
AUTO_MIGRATE=true
# MIGRATIONS_PATH=file://migrations

# AffilFlow JWT — required in production. If empty and APP_ENV=development, a dev default is used (see logs).
AUTH_JWT_SECRET=asdasdasd123adasd12
AUTH_JWT_ISSUER=affilflow
AUTH_JWT_AUDIENCE=affilflow-api
# Public URL of this API — OAuth redirect URIs are {AUTH_PUBLIC_BASE_URL}/api/v1/auth/providers/{google|facebook}/callback
AUTH_PUBLIC_BASE_URL=http://localhost:8080

# OAuth — register redirect URIs in Google Cloud / Facebook app settings
OAUTH_GOOGLE_CLIENT_ID=
OAUTH_GOOGLE_CLIENT_SECRET=
OAUTH_FACEBOOK_CLIENT_ID=
OAUTH_FACEBOOK_CLIENT_SECRET=

# Optional: first sign-in with this email becomes admin (dev/bootstrap)
# AUTH_BOOTSTRAP_ADMIN_EMAIL=you@example.com

# Dev only — never enable in production
JWT_SKIP_VALIDATION=false

# Invite links (Next.js app origin for /join/{token})
PUBLIC_APP_BASE_URL=http://localhost:3001

# Allowed hosts for OAuth post-login ?next= redirect (comma-separated, e.g. localhost:3001)
REDIRECT_ALLOW_HOSTS=localhost:3001

# Optional: default org UUID for webhooks when store is not registered (dev)
# DEFAULT_ORGANIZATION_ID=

# Referral redirect
REDIRECT_BASE_URL=https://example.com
REFERRAL_COOKIE_NAME=aff_ref
REFERRAL_COOKIE_TTL_HOURS=720

# Webhooks / payments / fabric (optional until integrated)
# SHOPIFY_WEBHOOK_SECRET=
# WOOCOMMERCE_URL=
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# STRIPE_BILLING_WEBHOOK_SECRET=
# PAYPAL_CLIENT_ID=
# PAYPAL_SECRET=
# PAYPAL_MODE=sandbox
# Hyperledger Fabric (optional — Docker dev network: see ../infra/fabric/README.md, make fabric-up)
# FABRIC_ENABLED=false
# FABRIC_NETWORK_CONFIG=/path/to/connection-profile.yaml
# FABRIC_CHANNEL=mychannel
# FABRIC_CHAINCODE=affilflow-cc
